        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <style>\n    body { font-family: Arial, sans-serif; background: #f5f5f4; margin: 0; padding: 0; }\n    .container { max-width: 600px; margin: 32px auto; background: #fff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e4e2; }\n    .header { background: #1c1917; padding: 28px 32px; }\n    .header h1 { color: #fff; font-size: 20px; margin: 0; font-weight: 700; letter-spacing: -0.02em; }\n    .header p { color: #a8a29e; font-size: 13px; margin: 6px 0 0; }\n    .body { padding: 28px 32px; }\n    .section-label { font-size: 11px; font-weight: 700; color: #a8a29e; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }\n    .section-content { background: #f5f5f4; border-radius: 8px; padding: 16px 18px; margin-bottom: 24px; font-size: 14px; color: #1c1917; line-height: 1.7; border: 1px solid #e5e4e2; white-space: pre-line; }\n    .meta { font-size: 12px; color: #78716c; margin-bottom: 24px; padding: 12px 16px; background: #fffbeb; border-radius: 8px; border: 1px solid #fde68a; }\n    .footer { padding: 16px 32px; border-top: 1px solid #e5e4e2; }\n    .footer p { font-size: 11px; color: #a8a29e; margin: 0; text-align: center; }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Article AI Analysis</h1>\n      <p>Your article has been analyzed by our AI workflow.</p>\n    </div>\n    <div class=\"body\">\n      <div class=\"meta\">\n        <strong>Session ID:</strong> {{ $('Merge Data').item.json.session_id }}<br>\n        <strong>Article:</strong> <a href=\"{{ $('Merge Data').item.json.article_url }}\" style=\"color: #2563eb; text-decoration: none;\">{{ $('Merge Data').item.json.title || $('Merge Data').item.json.article_url }}</a><br>\n        <strong>Submitted At:</strong> {{ $('Merge Data').item.json.timestamp }}\n      </div>\n      <div class=\"section-label\">Summary</div>\n      <div class=\"section-content\">{{ $('Merge Data').item.json.summary }}</div>\n      <div class=\"section-label\">Key Insights</div>\n      <div class=\"section-content\">{{ $('Merge Data').item.json.insights }}</div>\n    </div>\n    <div class=\"footer\">\n      <p>This email was generated automatically by Article AI.</p>\n    </div>\n  </div>\n</body>\n</html>",
