    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.GROQ_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\nJSON.stringify({\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert at extracting key insights from articles. Extract exactly 3 to 5 key insights from the article. Each insight should be a single actionable or noteworthy takeaway. Format your response as a numbered list, one insight per line. Do not add any extra commentary before or after the list.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Extract the key insights from the following article:\\n\\n\" + $('Firecrawl Scrape').item.json.data.markdown.substring(0, 12000)\n    }\n  ],\n  \"temperature\": 0.3,\n  \"max_tokens\": 512\n})\n}}",
        "options": {
          "timeout": 60000
        }
      },
