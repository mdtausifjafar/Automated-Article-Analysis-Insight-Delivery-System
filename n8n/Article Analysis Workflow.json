    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.GROQ_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\nJSON.stringify({\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert article summarizer. Summarize the given article in 3 to 5 clear, concise sentences. Focus on the main argument, key findings, and conclusion. Do not add any extra commentary. Return only the summary text.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Please summarize the following article:\\n\\n\" + $('Firecrawl Scrape').item.json.data.markdown.substring(0, 12000)\n    }\n  ],\n  \"temperature\": 0.3,\n  \"max_tokens\": 512\n})\n}}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "46ab6f6f-6a2a-4b38-8dec-b5fd0e409296",
      "name": "Groq Summarize",
      "type": "n8n-nodes-base.httpRequest",
